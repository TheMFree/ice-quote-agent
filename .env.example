# ICE Quote Agent — Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env.

# --- Anthropic / Claude API ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Microsoft 365 / Graph API ---
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# The mailbox the agent monitors and sends from
AGENT_MAILBOX=quotes@ice-contractors.com

# Reviewer — every draft is sent HERE first for review.
REVIEWER_EMAIL=mgfjr@bellsouth.net

# --- Agent behavior ---
POLL_INTERVAL_SECONDS=60
PROCESSED_FOLDER=Processed
FAILED_FOLDER=FailedToProcess
TEMPLATE_PATH=templates/ICE_Contractors_Proposal_Template.docx
OUTPUT_DIR=output
LOG_FILE=logs/agent.log

# Dry run mode: parse + fill template, but do NOT send email.
DRY_RUN=true
